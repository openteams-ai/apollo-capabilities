# Web search backend. Choose one: "tavily", "serper", "duckduckgo".
SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
SERPER_API_KEY=

# MCP exports only — not used for research LLM calls.
ANTHROPIC_API_KEY=
NOTION_MCP_URL=
LINEAR_MCP_URL=
HUBSPOT_MCP_URL=
